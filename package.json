{
  "name": "gui-forge",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "node server/dev.mjs",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.mjs",
    "start": "node server/index.mjs",
    "desktop:dev": "tauri dev",
    "desktop:stage-node": "powershell -ExecutionPolicy Bypass -File scripts/stage-node-sidecar.ps1",
    "desktop:build": "npm run desktop:stage-node && tauri build",
    "catalog:refresh": "node server/scripts/refresh-catalog.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run src --exclude src-tauri/**",
    "test:server": "node --test server/test/*.test.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
